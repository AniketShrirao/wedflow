{
  "name": "wedflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:accessibility": "vitest --run --config vitest.accessibility.config.ts",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "deploy": "node scripts/deploy.js",
    "deploy:prod": "node scripts/deploy.js --deploy",
    "security:audit": "npm audit --audit-level=high",
    "analyze": "ANALYZE=true npm run build",
    "backup": "node -e \"require('./src/lib/backup/database-backup.js').runScheduledBackup('full')\"",
    "backup:incremental": "node -e \"require('./src/lib/backup/database-backup.js').runScheduledBackup('incremental')\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sanity/client": "^6.10.0",
    "@sanity/image-url": "^1.0.2",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.39.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^2.32.0",
    "lucide-react": "^0.263.1",
    "next": "16.0.3",
    "next-sanity": "^7.1.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.10.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.49.1",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sanity/cli": "^3.57.4",
    "@sanity/icons": "^3.4.0",
    "@sanity/ui": "^2.8.9",
    "@sanity/vision": "^3.57.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "axe-core": "^4.10.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "jsdom": "^25.0.1",
    "lighthouse": "^12.2.1",
    "puppeteer": "^23.10.4",
    "sanity": "^3.57.4",
    "styled-components": "^6.1.13",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
